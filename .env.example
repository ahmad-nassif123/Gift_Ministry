# عنوان الموقع الكامل (لرموز QR في PDF وغيرها عند الحاجة خارج المتصفح)
# مثال: https://gift-catalog.vercel.app
# NEXT_PUBLIC_SITE_URL=

# ——— الشعار (اختياري) ———
# مسار ملف الشعار تحت public/، يبدأ بـ /. إن تركت فارغاً يُستخدم المسار الافتراضي في lib/config.ts (حالياً /logo.png).
# مثال: وضعت الملف public/logo-org.png  ← اضبط: NEXT_PUBLIC_SITE_LOGO_PATH=/logo-org.png
# ثم أعد البناء (npm run build) حتى يُحدَّث الواجهة والـ manifest.
# NEXT_PUBLIC_SITE_LOGO_PATH=

# ——— شعار ملفات الـPDF (اختياري) ———
# افتراضيًا يستخدم المشروع /logo_pdf.png داخل public/.
# مثال: NEXT_PUBLIC_PDF_LOGO_PATH=/logo_pdf.png
# NEXT_PUBLIC_PDF_LOGO_PATH=

# أيقونة الدرع (تبويب المتصفح + أيقونات PWA). الافتراضي في الكود: /emblem.png — انسخ الملف إلى app/icon.png و app/apple-icon.png أيضاً.
# NEXT_PUBLIC_SITE_ICON_PATH=

# ——— أمان لوحة التحكم (مهم للإنتاج) ———
# AUTH_SECRET: ضروري في الإنتاج. استخدم سلسلة عشوائية 32+ حرفاً (مثلاً: openssl rand -base64 32)
# بدونه يُستخدم سري افتراضي من الكود ويقل الأمان.
AUTH_SECRET=غيّر_هذا_إلى_سلسلة_عشوائية_طويلة_32_حرف_على_الأقل

# الإيميلات المسموح لها بالدخول (مفصولة بفاصلة)
ALLOWED_ADMIN_EMAILS=media.team.damascus.2@gmail.com,k42746859@gmail.com,abdulkarimsaad165@gmail.com

# كلمة سر عامة لجميع الحسابات — اختياري؛ إن تركتها فارغة واعتمدت فقط ADMIN_CREDENTIALS فلكل بريد كلمة سر خاصة
ADMIN_PASSWORD=

# كلمات سر لكل حساب (مفضل عند رفض كلمة سر مشتركة). الصيغة: email:كلمة_السر,email2:كلمة_السر2
# مثال: admin@example.com:StrongPass123,other@example.com:AnotherPass456
ADMIN_CREDENTIALS=

# كلمة مرور إضافية لفتح صفحة «حسابات الدخول» داخل لوحة التحكم (/dashboard/admin-directory)
# الافتراضي في الكود 20022026 — غيّرها في الإنتاج عبر المتغير التالي:
# ADMIN_DIRECTORY_GATE_PASSWORD=

# ——— توقيع رقمي لملفات PDF (اختياري) ———
# مسار شهادة PKCS#12 (p12/pfx) على الخادم فقط (لا تضعها داخل الريبو)
PDF_SIGN_P12_PATH=
# كلمة مرور الشهادة إن وجدت
PDF_SIGN_P12_PASSPHRASE=

# البريد الإلكتروني (إرسال PDF - اختياري)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
ORDER_EMAIL_TO=

# مسح الهدايا (Gift Scanner) — إضافة Postgres من لوحة Vercel: Storage → Create Database → Postgres
# يتم تعبئة المتغيرات تلقائياً بعد ربط قاعدة البيانات بالمشروع.
POSTGRES_URL=
# أو استخدم DATABASE_URL إن كنت تستخدم Neon/قاعدة أخرى
# DATABASE_URL=

# ——— ملاحظة أمان ———
# في الإنتاج: اضبط AUTH_SECRET و ADMIN_CREDENTIALS (أو ADMIN_PASSWORD) في Vercel → Project → Settings → Environment Variables.
# للتخفيف من هجمات التخمين على تسجيل الدخول يمكن لاحقاً إضافة Rate Limiting (مثلاً عبر Upstash).
