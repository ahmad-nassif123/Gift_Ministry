# عنوان الموقع الكامل (لرموز QR في PDF وغيرها عند الحاجة خارج المتصفح)
# مثال: https://gift-catalog.vercel.app
# NEXT_PUBLIC_SITE_URL=

# ——— الشعار (اختياري) ———
# مسار ملف الشعار تحت public/، يبدأ بـ /. إن تركت فارغاً يُستخدم المسار الافتراضي في lib/config.ts (حالياً /logo.png).
# مثال: وضعت الملف public/logo-org.png  ← اضبط: NEXT_PUBLIC_SITE_LOGO_PATH=/logo-org.png
# ثم أعد البناء (npm run build) حتى يُحدَّث الواجهة والـ manifest.
# NEXT_PUBLIC_SITE_LOGO_PATH=

# ——— شعار ملفات الـPDF (اختياري) ———
# افتراضيًا يستخدم المشروع /logo_pdf.png داخل public/.
# مثال: NEXT_PUBLIC_PDF_LOGO_PATH=/logo_pdf.png
# NEXT_PUBLIC_PDF_LOGO_PATH=

# أيقونة الدرع (تبويب المتصفح + أيقونات PWA). الافتراضي في الكود: /emblem.png — انسخ الملف إلى app/icon.png و app/apple-icon.png أيضاً.
# NEXT_PUBLIC_SITE_ICON_PATH=

# ——— أمان لوحة التحكم (مهم للإنتاج) ———
# ⚠️ لا تضع كلمات المرور الحقيقية في GitHub. استخدم Vercel → Settings → Environment Variables ثم Redeploy.
#
# الطريقة الموصى بها: Postgres مفعّل + جدول admin_accounts + إدارة البريدات من لوحة التحكم (حسابات الدخول).
# أول مرة فقط (عندما يكون جدول الحسابات فارغاً): عيّن ADMIN_BOOTSTRAP_EMAIL و ADMIN_BOOTSTRAP_PASSWORD في Vercel،
# سجّل الدخول مرة واحدة، ثم احذف هذين المتغيرين من البيئة وأعد النشر، وأضف باقي الحسابات من الداشبورد.
#
# POSTGRES_URL أو DATABASE_URL ضروريان لتخزين الحسابات ولأول تسجيل دخول بالـ bootstrap أعلاه.
#
# اختياري (Legacy): إن تركت ADMIN_CREDENTIALS أو ADMIN_PASSWORD أو ALLOWED_ADMIN_EMAILS معبّأة، يُستخدم ذلك أيضاً.
# AUTH_SECRET: ضروري في الإنتاج. استخدم سلسلة عشوائية 32+ حرفاً (مثلاً: openssl rand -base64 32)
AUTH_SECRET=غيّر_هذا_إلى_سلسلة_عشوائية_طويلة_32_حرف_على_الأقل

# قائمة بريدات إضافية مسموحة (فاصلة إنجليزية). غالباً تُترك فارغة وتُدار الحسابات من الداشبورد + القاعدة.
ALLOWED_ADMIN_EMAILS=

ADMIN_PASSWORD=

# صيغة: email:pass,email2:pass2 — اختياري إذا اعتمدت القاعدة فقط.
# إذا عُرّف البريد هنا فلا حاجة لإدراجه في ALLOWED_ADMIN_EMAILS.
ADMIN_CREDENTIALS=

# أول حساب مسؤول عندما admin_accounts فارغ (كلمة المرور 4 أحرف على الأقل). احذف المتغيرين بعد أول دخول ناجح.
# ADMIN_BOOTSTRAP_EMAIL=owner@example.com
# ADMIN_BOOTSTRAP_PASSWORD=

# كلمة مرور فتح صفحة «حسابات الدخول» في الداشبورد (/dashboard/admin-directory). الافتراضي في الكود 20022026.
# ADMIN_DIRECTORY_GATE_PASSWORD=

# ——— توقيع رقمي لملفات PDF (اختياري) ———
# مسار شهادة PKCS#12 (p12/pfx) على الخادم فقط (لا تضعها داخل الريبو)
PDF_SIGN_P12_PATH=
# كلمة مرور الشهادة إن وجدت
PDF_SIGN_P12_PASSPHRASE=

# البريد الإلكتروني (إرسال PDF - اختياري)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
ORDER_EMAIL_TO=

# مسح الهدايا (Gift Scanner) — إضافة Postgres من لوحة Vercel: Storage → Create Database → Postgres
# يتم تعبئة المتغيرات تلقائياً بعد ربط قاعدة البيانات بالمشروع.
POSTGRES_URL=
# أو استخدم DATABASE_URL إن كنت تستخدم Neon/قاعدة أخرى
# DATABASE_URL=

# ——— ملاحظة أمان ———
# في الإنتاج: AUTH_SECRET + POSTGRES_URL، وأول تسجيل ADMIN_BOOTSTRAP_* ثم احذفهما؛ أو Legacy عبر ADMIN_CREDENTIALS.
# للتخفيف من هجمات التخمين على تسجيل الدخول يمكن لاحقاً إضافة Rate Limiting (مثلاً عبر Upstash).
